---
interface Props {
  columns: Array<{ id: string; header: string; accessorKey?: string }>
  data: Array<Record<string, unknown>>
  selectable?: boolean
  exportFilename?: string
  class?: string
}
const { columns, data, selectable = false, exportFilename, class: className = '' } = Astro.props
---

<div
  class={`table-responsive ${className}`.trim()}
  data-table
  data-table-columns={JSON.stringify(columns)}
  data-table-data={JSON.stringify(data)}
  {...selectable ? { 'data-selectable': '' } : {}}
  {...exportFilename ? { 'data-export': exportFilename } : {}}
>
</div>

<script>
  import { initTables } from '@/scripts/table'

  document.addEventListener('astro:page-load', () => initTables())
</script>
