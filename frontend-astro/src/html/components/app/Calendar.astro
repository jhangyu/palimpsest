---
/**
 * Calendar - Month view with event CRUD
 * Pure Vanilla JS, no external libraries.
 * Persists events to localStorage.
 */
interface Props {
  events?: Array<{
    id: string
    title: string
    date: string
    color?: string
  }>
  storageKey?: string
}

const { events = [], storageKey = 'calendar-events' } = Astro.props
---

<div id="calendar-app" data-storage-key={storageKey} data-default-events={JSON.stringify(events)}>
  <div class="card">
    <div class="card-body">
      <div class="calendar-grid-container">
        <!-- Rendered by calendar.ts -->
      </div>
    </div>
  </div>
</div>

<!-- Calendar Event Modal -->
<div
  class="modal fade"
  id="calendar-modal"
  tabindex="-1"
  aria-labelledby="calendar-modal-label"
  aria-hidden="true"
>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="calendar-modal-label">Add Event</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="calendar-event-form">
        <div class="modal-body">
          <input type="hidden" id="calendar-event-id" />
          <div class="mb-3">
            <label for="calendar-event-title" class="form-label">Title</label>
            <input type="text" class="form-control" id="calendar-event-title" required />
          </div>
          <div class="mb-3">
            <label for="calendar-event-date" class="form-label">Date</label>
            <input type="date" class="form-control" id="calendar-event-date" required />
          </div>
          <div class="mb-3">
            <label for="calendar-event-color" class="form-label">Color</label>
            <input
              type="color"
              class="form-control form-control-color"
              id="calendar-event-color"
              value="#0d6efd"
            />
          </div>
        </div>
        <div class="modal-footer">
          <button
            type="button"
            class="btn btn-danger"
            id="calendar-event-delete"
            style="display:none">Delete</button
          >
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  import { initCalendar, destroyCalendar } from '../../../scripts/calendar'

  document.addEventListener('astro:page-load', () => {
    initCalendar()
  })

  document.addEventListener('astro:before-swap', () => {
    destroyCalendar()
  })
</script>
