---
interface Props {
  folders?: Array<{ name: string; icon: string; count?: number; key?: string }>
}

const { folders } = Astro.props
const foldersData = folders ? JSON.stringify(folders) : ''
---

<div class="inbox-app card" data-folders={foldersData}>
  <div class="card-body p-0">
    <div class="row g-0" style="min-height:500px">
      <!-- Folder list -->
      <div class="col-md-2 border-end">
        <div class="p-3">
          <button class="btn btn-primary w-100 mb-3">
            <i class="ri-edit-line me-1"></i> Compose
          </button>
          <div class="inbox-folders list-group list-group-flush"></div>
        </div>
      </div>
      <!-- Message list -->
      <div class="col-md-4 border-end">
        <div class="inbox-list" style="overflow-y:auto;max-height:600px"></div>
      </div>
      <!-- Preview -->
      <div class="col-md-6">
        <div class="inbox-preview" style="overflow-y:auto;max-height:600px"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .inbox-app :global(.inbox-msg-item) {
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .inbox-app :global(.inbox-msg-item:hover) {
    background-color: var(--bs-tertiary-bg, #f8f9fa);
  }

  .inbox-app :global(.avatar-circle) {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--bs-primary, #0d6efd);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .inbox-app :global(.list-group-item.active) {
    background-color: var(--bs-primary, #0d6efd);
    border-color: var(--bs-primary, #0d6efd);
  }

  .inbox-app :global(.message-body) {
    line-height: 1.7;
  }

  .inbox-app :global(.message-body p) {
    margin-bottom: 0.75rem;
  }

  .inbox-app :global(.star-btn) {
    padding: 0.125rem 0.25rem;
    line-height: 1;
  }

  .inbox-app :global(kbd) {
    padding: 2px 6px;
    font-size: 0.75rem;
    background-color: var(--bs-tertiary-bg, #e9ecef);
    border-radius: 3px;
    color: var(--bs-body-color, #212529);
  }
</style>

<script>
  import { initInbox } from '@/scripts/inbox'

  document.addEventListener('astro:page-load', () => initInbox())
</script>
