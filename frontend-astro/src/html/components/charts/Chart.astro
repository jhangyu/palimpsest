---
interface Props {
  id: string
  type: 'line' | 'bar' | 'pie' | 'doughnut'
  data: Record<string, unknown>
  height?: string
  class?: string
}
const { id, type, data, height = '320px', class: className = '' } = Astro.props
const dataJson = JSON.stringify(data)
---

<div
  class={`chart ${className}`}
  id={id}
  data-chart-type={type}
  data-chart-data={dataJson}
  style={`height:${height};width:100%`}
>
</div>

<script>
  import { initCharts } from '@/scripts/charts'

  document.addEventListener('astro:page-load', () => initCharts())
</script>
