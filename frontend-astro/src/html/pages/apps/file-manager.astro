---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import FileManager from '../../components/app/FileManager.astro'
import { getPathPrefix } from '../../../utils/path.js'

const pageHeaderProps = {
  title: 'File Manager',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Apps', href: '#' },
    { label: 'File Manager', class: 'active' }
  ]
}

const sampleFS = {
  name: 'My Files',
  children: [
    {
      name: 'Documents',
      type: 'folder' as const,
      modified: '2026-06-10',
      children: [
        {
          name: 'Project Proposal.pdf',
          type: 'file' as const,
          size: '2.4 MB',
          modified: '2026-06-08'
        },
        {
          name: 'Meeting Notes.docx',
          type: 'file' as const,
          size: '156 KB',
          modified: '2026-06-09'
        },
        { name: 'Budget 2026.xlsx', type: 'file' as const, size: '890 KB', modified: '2026-06-10' },
        {
          name: 'Reports',
          type: 'folder' as const,
          modified: '2026-06-05',
          children: [
            {
              name: 'Q1 Report.pdf',
              type: 'file' as const,
              size: '3.1 MB',
              modified: '2026-04-01'
            },
            { name: 'Q2 Report.pdf', type: 'file' as const, size: '2.8 MB', modified: '2026-06-05' }
          ]
        }
      ]
    },
    {
      name: 'Images',
      type: 'folder' as const,
      modified: '2026-06-12',
      children: [
        { name: 'logo.png', type: 'file' as const, size: '45 KB', modified: '2026-05-20' },
        { name: 'banner.jpg', type: 'file' as const, size: '1.2 MB', modified: '2026-06-12' },
        { name: 'avatar.svg', type: 'file' as const, size: '8 KB', modified: '2026-06-01' }
      ]
    },
    {
      name: 'Downloads',
      type: 'folder' as const,
      modified: '2026-06-15',
      children: [
        { name: 'installer.exe', type: 'file' as const, size: '45.2 MB', modified: '2026-06-15' },
        { name: 'archive.zip', type: 'file' as const, size: '12.8 MB', modified: '2026-06-14' }
      ]
    },
    {
      name: 'Videos',
      type: 'folder' as const,
      modified: '2026-06-01',
      children: [
        { name: 'presentation.mp4', type: 'file' as const, size: '128 MB', modified: '2026-06-01' }
      ]
    },
    { name: 'readme.txt', type: 'file' as const, size: '4 KB', modified: '2026-01-15' },
    { name: 'config.json', type: 'file' as const, size: '1 KB', modified: '2026-03-22' }
  ]
}
---

<AdminLayout
  currentPath="apps/file-manager"
  title="File Manager"
  description="Browse and manage files and folders"
>
  <PageHeader {...pageHeaderProps} />
  <div class="row">
    <div class="col-12">
      <FileManager rootFolder={sampleFS} />
    </div>
  </div>
</AdminLayout>
