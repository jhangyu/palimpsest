---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import Calendar from '../../components/app/Calendar.astro'

const now = new Date()
const year = now.getFullYear()
const month = now.getMonth()

function pad(n: number): string {
  return String(n).padStart(2, '0')
}

const sampleEvents = [
  {
    id: 'evt-1',
    title: 'Team Standup',
    date: `${year}-${pad(month + 1)}-${pad(3)}`,
    color: '#0d6efd'
  },
  {
    id: 'evt-2',
    title: 'Sprint Planning',
    date: `${year}-${pad(month + 1)}-${pad(5)}`,
    color: '#198754'
  },
  {
    id: 'evt-3',
    title: 'Design Review',
    date: `${year}-${pad(month + 1)}-${pad(10)}`,
    color: '#6f42c1'
  },
  {
    id: 'evt-4',
    title: 'Product Demo',
    date: `${year}-${pad(month + 1)}-${pad(15)}`,
    color: '#fd7e14'
  },
  {
    id: 'evt-5',
    title: 'Retrospective',
    date: `${year}-${pad(month + 1)}-${pad(18)}`,
    color: '#dc3545'
  },
  {
    id: 'evt-6',
    title: 'Release Day',
    date: `${year}-${pad(month + 1)}-${pad(22)}`,
    color: '#0dcaf0'
  },
  {
    id: 'evt-7',
    title: 'Team Lunch',
    date: `${year}-${pad(month + 1)}-${pad(25)}`,
    color: '#ffc107'
  },
  {
    id: 'evt-8',
    title: 'Board Meeting',
    date: `${year}-${pad(month + 1)}-${pad(28)}`,
    color: '#198754'
  }
]
---

<AdminLayout
  currentPath="apps/calendar"
  title="Calendar"
  description="Event calendar with month view"
>
  <PageHeader title="Calendar" />
  <Calendar events={sampleEvents} storageKey="calendar-demo" />
</AdminLayout>
