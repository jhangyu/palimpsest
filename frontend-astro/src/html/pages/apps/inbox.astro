---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import Inbox from '../../components/app/Inbox.astro'
import { getPathPrefix } from '../../../utils/path.js'

const pageHeaderProps = {
  title: 'Inbox',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Apps', href: '#' },
    { label: 'Inbox', class: 'active' }
  ]
}

const inboxFolders = [
  { name: 'Inbox', icon: 'ri-inbox-fill', count: 4, key: 'inbox' },
  { name: 'Sent', icon: 'ri-send-plane-fill', count: 0, key: 'sent' },
  { name: 'Drafts', icon: 'ri-draft-fill', count: 1, key: 'drafts' },
  { name: 'Starred', icon: 'ri-star-fill', count: 0, key: 'starred' },
  { name: 'Trash', icon: 'ri-delete-bin-fill', count: 0, key: 'trash' }
]
---

<AdminLayout
  currentPath="apps/inbox"
  title="Inbox"
  description="Email inbox with keyboard shortcuts"
>
  <PageHeader {...pageHeaderProps} />
  <div class="row">
    <div class="col-12">
      <Inbox folders={inboxFolders} />
    </div>
  </div>
</AdminLayout>
