---
// ---
// name: forgot-password
// description: "Forgot password page: email address form that triggers a password reset link to be sent to the user's email"
// type: page
// target:
//   layer: frontend
//   domain: auth
// spec_doc: null
// test_file: null
// route: /authentication/modern/forgot-password
// ---
import AuthenticationLayout from '../../../layouts/admin/authentication-layout.astro'
import { getAssetPrefix, getPathPrefix } from '../../../../utils/path.js'
---

<AuthenticationLayout
  title="Forgot Password"
  description="Reset your password"
  currentPath="authentication/modern/forgot-password"
>
  <div
    class="d-flex justify-content-center align-items-center min-vh-100 pt-5 mt-2 pt-sm-0 mt-sm-0"
  >
    <div class="text-center w-100" style="max-width: 480px;">
      <!-- Main Card -->
      <div class="card m-2">
        <div class="card-body p-4">
          <!-- Company Logo -->
          <img
            src={getAssetPrefix('/assets/svg/astero-icon-color.svg')}
            alt="Palimpsest"
            class="mb-4"
            style="width: 40px; height: 40px;"
          />
          <h4 class="card-title mb-2 fs-4">Forgot your password?</h4>
          <p class="text-muted mb-3">Enter your email address and we'll send you a reset link.</p>

          <!-- Forgot Password Form -->
          <form id="forgot-password-form" class="text-start mb-3">
            <div class="mb-3">
              <label for="email" class="form-label">Email Address</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                placeholder="yourname@example.com"
                autocomplete="username"
                required
              />
            </div>
            <button type="submit" class="btn btn-primary w-100">
              <i class="ri-send-plane-line me-2"></i>Send Reset Link
            </button>
          </form>

          <div class="mb-2">
            Remember your password?
            <a href={getPathPrefix('/authentication/modern/login')} class="text-decoration-none"
              >Sign in</a
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</AuthenticationLayout>

<script>
  import { initForgotPasswordPage } from '@/scripts/auth'
  initForgotPasswordPage()
</script>
