---
import AuthenticationLayout from '../../../layouts/admin/authentication-layout.astro'
import { getAssetPrefix, getPathPrefix } from '../../../../utils/path.js'
---

<AuthenticationLayout
  title="Create Account"
  description="Create a new account"
  currentPath="authentication/modern/register"
>
  <div
    class="d-flex justify-content-center align-items-center min-vh-100 pt-5 mt-2 pt-sm-0 mt-sm-0"
  >
    <a
      href={getPathPrefix('/authentication/modern/login')}
      class="btn btn-outline-primary position-absolute top-0 end-0 m-3"
    >
      Sign In
    </a>
    <div class="text-center w-100" style="max-width: 520px;">
      <!-- Main Card -->
      <div class="card m-2">
        <div class="card-body p-4">
          <!-- Company Logo -->
          <img
            src={getAssetPrefix('/assets/svg/astero-icon-color.svg')}
            alt="Palimpsest"
            class="mb-4"
            style="width: 40px; height: 40px;"
          />
          <h4 class="card-title mb-2 fs-4">Create a new account</h4>

          <!-- Registration disabled notice (shown when backend returns 403) -->
          <div
            id="registration-disabled-alert"
            class="alert alert-warning d-flex align-items-center gap-2 mb-3"
            role="alert"
            hidden
          >
            <i class="ri-information-line flex-shrink-0"></i>
            <span>Public registration is currently disabled. Please contact an administrator.</span>
          </div>

          <form id="register-form" class="text-start my-3">
            <div class="mb-3">
              <label for="full_name" class="form-label">Full Name</label>
              <input
                type="text"
                class="form-control"
                id="full_name"
                name="full_name"
                placeholder="Your Name"
                autocomplete="name"
              />
            </div>
            <div class="mb-3">
              <label for="username" class="form-label"
                >Username <span class="text-danger">*</span></label
              >
              <input
                type="text"
                class="form-control"
                id="username"
                name="username"
                placeholder="lowercase letters only, max 20 chars"
                autocomplete="nickname"
                required
                maxlength="20"
                pattern="[a-z]{1,20}"
                title="Lowercase English letters only, 1-20 characters"
              />
            </div>
            <div class="mb-3">
              <label for="email" class="form-label"
                >Email Address <span class="text-danger">*</span></label
              >
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                placeholder="yourname@example.com"
                autocomplete="username"
                required
              />
            </div>
            <div class="mb-3">
              <label for="password" class="form-label"
                >Password <span class="text-danger">*</span></label
              >
              <div class="password-wrapper">
                <input
                  type="password"
                  class="form-control password-input"
                  id="password"
                  name="password"
                  placeholder="8-20 characters"
                  autocomplete="new-password"
                  required
                  minlength="8"
                  maxlength="20"
                />
                <button class="password-toggle" type="button" aria-label="Show password">
                  <i class="ri-eye-off-line"></i>
                </button>
              </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3">
              <i class="ri-user-add-line me-2"></i>Create Account
            </button>
          </form>

          <div class="mb-2">
            <span class="text-muted">
              Already have an account? <a
                href={getPathPrefix('/authentication/modern/login')}
                class="text-decoration-none">Sign in</a
              >
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</AuthenticationLayout>

<script>
  import { initRegisterPage } from '@/scripts/auth'

  // Override the default register handler to also handle 403 (registration disabled)
  const form = document.querySelector<HTMLFormElement>('#register-form')
  const disabledAlert = document.getElementById('registration-disabled-alert')

  if (form) {
    // initRegisterPage will attach the submit handler;
    // if the backend returns a 403 detail, it will be shown via showFormError.
    // We additionally check if the error message matches registration disabled.
    form.addEventListener('submit', () => {
      if (disabledAlert) disabledAlert.setAttribute('hidden', '')
    })
  }

  initRegisterPage()
</script>
