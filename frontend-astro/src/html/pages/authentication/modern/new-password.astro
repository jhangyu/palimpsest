---
import AuthenticationLayout from '../../../layouts/admin/authentication-layout.astro'
import { getAssetPrefix, getPathPrefix } from '../../../../utils/path.js'
---

<AuthenticationLayout
  title="Set New Password"
  description="Set your new password"
  currentPath="authentication/modern/new-password"
>
  <div
    class="d-flex justify-content-center align-items-center min-vh-100 pt-5 mt-2 pt-sm-0 mt-sm-0"
  >
    <div class="text-center w-100" style="max-width: 480px;">
      <!-- Main Card -->
      <div class="card m-2">
        <div class="card-body p-4">
          <!-- Company Logo -->
          <img
            src={getAssetPrefix('/assets/svg/astero-icon-color.svg')}
            alt="Palimpsest"
            class="mb-4"
            style="width: 40px; height: 40px;"
          />
          <h4 class="card-title mb-2 fs-4">Set Your New Password</h4>
          <p class="text-muted mb-3">Choose a strong password between 8 and 20 characters.</p>

          <!-- Reset Password Form -->
          <form id="reset-password-form" class="text-start mb-3">
            <div class="mb-3">
              <label for="new-password" class="form-label">New Password</label>
              <div class="password-wrapper">
                <input
                  type="password"
                  class="form-control password-input"
                  id="new-password"
                  name="password"
                  placeholder="Password"
                  autocomplete="new-password"
                  required
                  minlength="8"
                  maxlength="20"
                />
                <button class="password-toggle" type="button" aria-label="Show password">
                  <i class="ri-eye-off-line"></i>
                </button>
              </div>
            </div>
            <div class="mb-3">
              <label for="confirm-password" class="form-label">Confirm Password</label>
              <div class="password-wrapper">
                <input
                  type="password"
                  class="form-control password-input"
                  id="confirm-password"
                  name="password_confirm"
                  placeholder="Password"
                  autocomplete="new-password"
                  required
                />
                <button class="password-toggle" type="button" aria-label="Show password">
                  <i class="ri-eye-off-line"></i>
                </button>
              </div>
            </div>
            <button type="submit" class="btn btn-primary w-100">
              <i class="ri-shield-check-line me-2"></i>Save New Password
            </button>
          </form>

          <div class="mb-2">
            <a href={getPathPrefix('/authentication/modern/login')} class="text-decoration-none"
              >Back to Sign In</a
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</AuthenticationLayout>

<script>
  import { initResetPasswordPage } from '@/scripts/auth'
  initResetPasswordPage()
</script>
