---
import AuthenticationLayout from '../../../layouts/admin/authentication-layout.astro'
import { getAssetPrefix, getPathPrefix } from '../../../../utils/path.js'
---

<AuthenticationLayout
  title="Login"
  description="Sign in to your account"
  currentPath="authentication/modern/login"
>
  <div
    class="d-flex justify-content-center align-items-center min-vh-100 pt-5 mt-2 pt-sm-0 mt-sm-0"
  >
    <div class="text-center w-100" style="max-width: 480px;">
      <!-- Main Card -->
      <div class="card m-2">
        <div class="card-body p-4">
          <!-- Company Logo -->
          <img
            src={getAssetPrefix('/assets/svg/astero-icon-color.svg')}
            alt="Palimpsest"
            class="mb-4"
            style="width: 40px; height: 40px;"
          />
          <h4 class="card-title mb-2 fs-4">Sign in to your account</h4>

          <!-- Login success hint from reset flow -->
          <div
            id="reset-success-alert"
            class="alert alert-success d-flex align-items-center gap-2 mb-3"
            role="alert"
            hidden
          >
            <i class="ri-checkbox-circle-line flex-shrink-0"></i>
            <span>Password reset successful. Please sign in with your new password.</span>
          </div>

          <!-- Login success hint from first-run setup -->
          <div
            id="setup-success-alert"
            class="alert alert-success d-flex align-items-center gap-2 mb-3"
            role="alert"
            hidden
          >
            <i class="ri-shield-check-line flex-shrink-0"></i>
            <span>Admin account created. Please sign in.</span>
          </div>

          <form id="login-form" class="text-start my-3">
            <div class="mb-3">
              <label for="email" class="form-label">Email Address</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                placeholder="yourname@example.com"
                autocomplete="username"
                required
              />
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <div class="password-wrapper">
                <input
                  type="password"
                  class="form-control password-input"
                  id="password"
                  name="password"
                  placeholder="Password"
                  autocomplete="current-password"
                  required
                />
                <button class="password-toggle" type="button" aria-label="Show password">
                  <i class="ri-eye-off-line"></i>
                </button>
              </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3">
              <i class="ri-login-box-line me-2"></i>Sign In
            </button>
          </form>

          <div class="mb-2">
            <a
              href={getPathPrefix('/authentication/modern/forgot-password')}
              class="text-decoration-none text-center">Forgot your password?</a
            >
          </div>
          <div class="mb-2">
            <a
              href={getPathPrefix('/authentication/modern/setup')}
              class="text-decoration-none text-center text-muted"
              style="font-size: 0.85rem;">First time? Set up admin account</a
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</AuthenticationLayout>

<script>
  import { initLoginPage } from '@/scripts/auth'

  // Show reset success hint if redirected from reset-password flow
  const params = new URLSearchParams(window.location.search)
  if (params.get('reset') === 'success') {
    const alert = document.getElementById('reset-success-alert')
    if (alert) alert.removeAttribute('hidden')
  }

  // Show setup success hint if redirected from first-run setup
  if (params.get('setup') === 'success') {
    const setupAlert = document.getElementById('setup-success-alert')
    if (setupAlert) setupAlert.removeAttribute('hidden')
  }

  initLoginPage()
</script>
