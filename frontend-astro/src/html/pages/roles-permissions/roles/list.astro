---
import AdminLayout from '../../../layouts/admin/admin-layout.astro'
import PageHeader from '../../../components/common/page-header.astro'
import type { Props as PageHeaderProps } from '../../../components/common/page-header.astro'
import { getPathPrefix } from '../../../../utils/path.js'

const pageHeaderProps: PageHeaderProps = {
  title: 'Roles',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard'), class: '' },
    { label: 'Roles & Permissions', href: getPathPrefix('/roles-permissions'), class: '' },
    { label: 'Roles', class: 'active' }
  ]
}
---

<AdminLayout
  title="Roles"
  description="Roles Management"
  currentPath="roles-permissions/roles/list"
>
  <PageHeader {...pageHeaderProps} />

  <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="ri-information-line"></i>
    <span
      >Roles are read-only in v1. The system provides two seeded roles: <strong>admin</strong> and <strong
        >user</strong
      >.</span
    >
  </div>

  <!-- Roles Cards — populated by initRolesListPage() -->
  <div id="roles-list-container">
    <div class="text-center py-5">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { initRolesListPage } from '@/scripts/users'
  document.addEventListener('DOMContentLoaded', () => {
    initRolesListPage()
  })
</script>
