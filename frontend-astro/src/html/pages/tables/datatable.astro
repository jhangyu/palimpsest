---

<AdminLayout
  title="DataTables"
  description="Advanced data tables powered by TanStack Table"
  currentPath="tables/datatable"
>
  <PageHeader {...pageHeaderProps} />

  <!-- Products Table with Selection & Export -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">Products Management Table</h5>
          <p class="text-muted mb-0 mt-1">
            Sortable columns, global search, row selection, pagination, and CSV export.
          </p>
        </div>
        <div class="card-body">
          <Table columns={productColumns} data={productData} selectable exportFilename="products" />
        </div>
      </div>
    </div>
  </div>

  <!-- Orders Table -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">Orders Table</h5>
          <p class="text-muted mb-0 mt-1">Standard table with sorting, search, and pagination.</p>
        </div>
        <div class="card-body">
          <Table columns={orderColumns} data={orderData} exportFilename="orders" />
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
