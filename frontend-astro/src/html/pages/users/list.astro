---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import { getPathPrefix } from '../../../utils/path.js'

const userListHeaderConfig = {
  title: 'Users Management',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Users' },
    { label: 'User List', class: 'active' }
  ],
  actions: [
    {
      label: 'Add User',
      href: getPathPrefix('/users/add'),
      icon: 'ri-user-add-line',
      class: 'btn btn-primary'
    }
  ]
}
---

<AdminLayout
  title="User Management"
  description="Manage and monitor user accounts"
  currentPath="users/list"
>
  <PageHeader {...userListHeaderConfig} />

  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div class="search-wrapper" style="min-width:260px;">
            <i class="ri-search-line search-icon"></i>
            <input
              type="text"
              class="form-control search-input"
              id="user-search-input"
              placeholder="Search by username or email..."
            />
          </div>
          <div>
            <a href={getPathPrefix('/users/add')} class="btn btn-primary btn-sm">
              <i class="ri-user-add-line me-1"></i>Add User
            </a>
          </div>
        </div>
        <div class="card-body p-0">
          <div id="user-list-container" class="p-3">
            <div class="text-center py-5">
              <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { initUserListPage } from '@/scripts/users'

  const init = () => {
    initUserListPage()
  }

  document.addEventListener('astro:page-load', init)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init)
  } else {
    init()
  }
</script>
