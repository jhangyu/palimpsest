---
// ---
// name: users-ai-service
// description: "AI service settings: runtime status display, AI provider list with drag-to-reorder fallback priority, per-provider enable/disable, add provider button, and environment fallback status"
// type: page
// target:
//   layer: frontend
//   domain: users
// spec_doc: null
// test_file: tests/stage2/e2e/stage2/ai-service.spec.ts
// route: /users/ai-service
// ---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import type { Props as PageHeaderProps } from '../../components/common/page-header.astro'
import { getPathPrefix } from '../../../utils/path.js'

const pageHeaderProps: PageHeaderProps = {
  title: 'AI Service',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard'), class: '' },
    { label: 'Users', href: getPathPrefix('/users'), class: '' },
    { label: 'AI Service', class: 'active' }
  ]
}
---

<AdminLayout
  title="AI Service"
  description="Manage AI provider settings"
  currentPath="users/ai-service"
>
  <PageHeader {...pageHeaderProps} />
  <div class="row g-4">
    <!-- User Profile Sidebar -->
    <div class="col-lg-3">
      <div class="card p-3">
        <div class="card-header text-center pt-3">
          <div class="position-relative d-inline-block mb-4">
            <div
              class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
              style="width:120px;height:120px;"
            >
              <i class="ri-user-line text-white" style="font-size:3rem;"></i>
            </div>
          </div>
          <h5 class="mb-1" data-session="user-name">Loading...</h5>
          <p class="text-muted mb-0">
            <i class="ri-mail-line me-1"></i><span data-session="user-email"></span>
          </p>
        </div>
        <div class="card-body">
          <nav class="nav-tree">
            <ul class="list-unstyled">
              <li class="nav-section">
                <span class="nav-section-text text-uppercase px-2">Personal</span>
              </li>
              <li class="nav-item">
                <a class="nav-link" href={getPathPrefix('/users/profile')}>
                  <i class="ri-user-line"></i>
                  <span>Profile</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href={getPathPrefix('/users/security')}>
                  <i class="ri-shield-check-line"></i>
                  <span>Security</span>
                </a>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href={getPathPrefix('/users/ai-service')}>
                  <i class="ri-robot-line"></i>
                  <span>AI Service</span>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>

    <!-- AI Service Settings -->
    <div class="col-lg-9">
      <!-- Runtime Status -->
      <div class="card mb-4">
        <div class="card-header">
          <div class="d-flex align-items-center">
            <i class="ri-pulse-line me-2"></i>
            <h5 class="card-title mb-0">Runtime Status</h5>
          </div>
        </div>
        <div class="card-body" id="ai-runtime-status">
          <!-- TS module renders here -->
          <div class="text-center py-3">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Provider List -->
      <div class="card mb-4">
        <div class="card-header">
          <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
              <i class="ri-settings-3-line me-2"></i>
              <h5 class="card-title mb-0">AI Providers</h5>
            </div>
            <button type="button" class="btn btn-primary btn-sm" id="ai-add-provider-btn">
              <i class="ri-add-line me-1"></i>Add Provider
            </button>
          </div>
        </div>
        <div class="card-body">
          <div class="alert alert-info d-flex align-items-start mb-4" role="alert">
            <i class="ri-information-line me-2 flex-shrink-0 mt-1"></i>
            <div>
              Providers are tried in order during AI analysis. Drag or use arrows to set fallback
              priority. Each provider can be individually enabled or disabled.
            </div>
          </div>
          <div id="ai-providers-list">
            <div class="text-center py-4">
              <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
              <p class="text-muted mt-2">Loading providers...</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Environment Fallback -->
      <div class="card">
        <div class="card-header">
          <div class="d-flex align-items-center">
            <i class="ri-server-line me-2"></i>
            <h5 class="card-title mb-0">Environment Fallback</h5>
          </div>
        </div>
        <div class="card-body" id="ai-env-fallback-status">
          <!-- TS module renders here -->
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { initAIServicePage } from '@/scripts/ai-service'

  const init = () => {
    initAIServicePage()
  }

  document.addEventListener('DOMContentLoaded', init)
  document.addEventListener('astro:page-load', init)
</script>
