---
// ---
// name: users-security
// description: "Account security settings: password change form with current/new/confirm fields; all other sessions are revoked on password change"
// type: page
// target:
//   layer: frontend
//   domain: users
// spec_doc: null
// test_file: tests/stage2/e2e/stage2/security.spec.ts
// route: /users/security
// ---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import type { Props as PageHeaderProps } from '../../components/common/page-header.astro'
import { getPathPrefix } from '../../../utils/path.js'

const securitySettingsConfig: PageHeaderProps = {
  title: 'Security Settings',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard'), class: '' },
    { label: 'Users', href: getPathPrefix('/users'), class: '' },
    { label: 'Security', class: 'active' }
  ]
}
---

<AdminLayout
  title="Account Security"
  description="Manage your account security and authentication settings"
  currentPath="users/security"
>
  <PageHeader {...securitySettingsConfig} />
  <div class="row g-4">
    <!-- User Profile Sidebar -->
    <div class="col-lg-3">
      <div class="card p-3">
        <div class="card-header text-center pt-3">
          <div class="position-relative d-inline-block mb-4">
            <div
              class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
              style="width:120px;height:120px;"
            >
              <i class="ri-user-line text-white" style="font-size:3rem;"></i>
            </div>
          </div>
          <h5 class="mb-1" data-session="user-name">Loading...</h5>
          <p class="text-muted mb-0">
            <i class="ri-mail-line me-1"></i><span data-session="user-email"></span>
          </p>
        </div>
        <div class="card-body">
          <nav class="nav-tree">
            <ul class="list-unstyled">
              <li class="nav-section">
                <span class="nav-section-text text-uppercase px-2">Personal</span>
              </li>
              <li class="nav-item">
                <a class="nav-link" href={getPathPrefix('/users/profile')}>
                  <i class="ri-user-line"></i>
                  <span>Profile</span>
                </a>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href={getPathPrefix('/users/security')}>
                  <i class="ri-shield-check-line"></i>
                  <span>Security</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href={getPathPrefix('/users/ai-service')}>
                  <i class="ri-robot-line"></i>
                  <span>AI Service</span>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>

    <!-- Security Settings -->
    <div class="col-lg-9">
      <!-- Password Management -->
      <div class="card">
        <div class="card-header bg-transparent">
          <div class="d-flex align-items-center">
            <i class="ri-lock-password-line me-2"></i>
            <h5 class="card-title mb-0">Change Password</h5>
          </div>
        </div>
        <div class="card-body">
          <!-- Success banner (hidden by default) -->
          <div
            id="password-success-alert"
            class="alert alert-success"
            style="display:none;"
            role="alert"
          >
            <i class="ri-shield-check-line me-2"></i>
            <strong>Password changed successfully.</strong>
            All other sessions have been revoked for your security.
          </div>

          <form id="passwordUpdateForm">
            <div class="row g-3">
              <!-- Current Password -->
              <div class="col-12">
                <label class="form-label required" for="currentPassword">Current Password</label>
                <div class="password-wrapper">
                  <input
                    type="password"
                    class="form-control password-input"
                    id="currentPassword"
                    placeholder="Enter current password"
                    autocomplete="current-password"
                    required
                  />
                  <button class="password-toggle" type="button" title="Toggle password visibility">
                    <i class="ri-eye-off-line"></i>
                  </button>
                </div>
              </div>
              <!-- New Password -->
              <div class="col-12">
                <label class="form-label required" for="newPassword">New Password</label>
                <div class="d-flex align-items-center gap-2">
                  <div class="password-wrapper w-100">
                    <input
                      type="password"
                      class="form-control password-input"
                      id="newPassword"
                      placeholder="Enter new password (8-20 characters)"
                      autocomplete="new-password"
                      minlength="8"
                      maxlength="20"
                      required
                    />
                    <button
                      class="password-toggle"
                      type="button"
                      title="Toggle password visibility"
                    >
                      <i class="ri-eye-off-line"></i>
                    </button>
                  </div>
                </div>
                <div class="form-text">
                  <i class="ri-information-line me-1"></i>8-20 characters required.
                </div>
              </div>
              <!-- Confirm New Password -->
              <div class="col-12">
                <label class="form-label required" for="confirmPassword">Confirm New Password</label
                >
                <div class="password-wrapper">
                  <input
                    type="password"
                    class="form-control password-input"
                    id="confirmPassword"
                    placeholder="Re-enter new password"
                    autocomplete="new-password"
                    required
                  />
                  <button class="password-toggle" type="button" title="Toggle password visibility">
                    <i class="ri-eye-off-line"></i>
                  </button>
                </div>
              </div>
              <div class="col-12 text-end mt-4">
                <button type="submit" class="btn btn-primary">
                  <i class="ri-save-line me-1"></i>Update Password
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- AI Service (moved to dedicated page) -->
      <div class="card mt-4">
        <div class="card-body">
          <div class="d-flex gap-3 align-items-center">
            <i class="ri-robot-line text-primary fs-3"></i>
            <div>
              <h6 class="mb-1">AI Service</h6>
              <p class="text-muted mb-0 small">
                AI provider settings have moved to a dedicated page.
              </p>
            </div>
            <a
              href={getPathPrefix('/users/ai-service')}
              class="btn btn-outline-primary btn-sm ms-auto"
            >
              <i class="ri-arrow-right-line me-1"></i>Go to AI Service
            </a>
          </div>
        </div>
      </div>

      <!-- Security Note -->
      <div class="card mt-4">
        <div class="card-body">
          <div class="d-flex gap-3">
            <i class="ri-shield-star-line text-primary fs-3"></i>
            <div>
              <h6 class="mb-1">Session Security</h6>
              <p class="text-muted mb-0 small">
                When you change your password, all other active sessions are automatically revoked.
                You will remain logged in on this device.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { initSecurityPage } from '@/scripts/users'

  const init = () => {
    initSecurityPage()
  }

  document.addEventListener('DOMContentLoaded', init)
  document.addEventListener('astro:page-load', init)
</script>
