---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import type { Props as PageHeaderProps } from '../../components/common/page-header.astro'
import { getPathPrefix } from '../../../utils/path.js'

const userEditHeaderConfig: PageHeaderProps = {
  title: 'Edit User',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard'), class: '' },
    { label: 'Users', href: getPathPrefix('/users/list'), class: '' },
    { label: 'Edit', class: 'active' }
  ],
  actions: [
    {
      label: 'Back',
      href: getPathPrefix('/users/list'),
      type: 'link',
      variant: 'btn-outline-primary',
      icon: 'ri-arrow-left-s-line',
      class: ''
    }
  ]
}
---

<AdminLayout
  title="Edit User Account"
  description="Update user account information"
  currentPath="users/edit"
>
  <PageHeader {...userEditHeaderConfig} />

  <form id="edit-user-form" class="row g-4" novalidate>
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <div class="d-flex align-items-center">
            <i class="ri-user-settings-line me-2"></i>
            <h5 class="card-title mb-0">User Information</h5>
          </div>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label required" for="edit-user-email">Email Address</label>
            <input
              type="email"
              class="form-control"
              id="edit-user-email"
              placeholder="user@example.com"
              autocomplete="off"
              required
            />
            <div class="form-text">
              <i class="ri-information-line me-1"></i>
              Email changes will require verification by the user.
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label required" for="edit-user-username">Username</label>
            <div class="input-group">
              <span class="input-group-text"><i class="ri-at-line"></i></span>
              <input
                type="text"
                class="form-control"
                id="edit-user-username"
                placeholder="lowercase letters only, 1-20 chars"
                maxlength="20"
                pattern="[a-z]{1,20}"
                required
              />
            </div>
            <div class="form-text">Lowercase English letters only (a-z), 1-20 characters.</div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="edit-user-full-name">Full Name</label>
            <input
              type="text"
              class="form-control"
              id="edit-user-full-name"
              placeholder="Optional"
              autocomplete="off"
            />
          </div>

          <div class="mb-3">
            <label class="form-label" for="edit-user-status">Account Status</label>
            <select class="form-select" id="edit-user-status">
              <option value="active">Active</option>
              <option value="blocked">Blocked</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <div class="d-flex align-items-center">
            <i class="ri-shield-keyhole-line me-2"></i>
            <h5 class="card-title mb-0">Roles</h5>
          </div>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">Modify roles assigned to this user.</p>
          <div class="mb-2">
            <div class="form-check">
              <input
                class="form-check-input"
                type="checkbox"
                name="role"
                id="role-admin"
                value="admin"
              />
              <label class="form-check-label" for="role-admin">
                <span class="fw-semibold"><i class="ri-admin-line me-1"></i>Administrator</span>
                <span class="d-block text-muted small">Full system access, user management</span>
              </label>
            </div>
          </div>
          <div class="mb-2">
            <div class="form-check">
              <input
                class="form-check-input"
                type="checkbox"
                name="role"
                id="role-user"
                value="user"
              />
              <label class="form-check-label" for="role-user">
                <span class="fw-semibold"><i class="ri-user-line me-1"></i>User</span>
                <span class="d-block text-muted small"
                  >Standard access to feeds, articles, analytics</span
                >
              </label>
            </div>
          </div>
        </div>
        <div class="card-footer d-flex justify-content-end gap-2">
          <a href={getPathPrefix('/users/list')} class="btn btn-outline-secondary">
            <i class="ri-arrow-left-line me-1"></i>Cancel
          </a>
          <button type="submit" class="btn btn-primary">
            <i class="ri-save-line me-1"></i>Save Changes
          </button>
        </div>
      </div>

      <div class="card mt-3">
        <div class="card-body">
          <div class="d-flex gap-2">
            <i class="ri-shield-star-line text-warning mt-1"></i>
            <p class="text-muted small mb-0">
              Admin cannot set or view plaintext passwords. Blocking a user will revoke all their
              active sessions immediately.
            </p>
          </div>
        </div>
      </div>
    </div>
  </form>
</AdminLayout>

<script>
  import { initEditUserPage } from '@/scripts/users'
  document.addEventListener('DOMContentLoaded', () => {
    initEditUserPage()
  })
</script>
