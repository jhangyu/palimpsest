---
import AdminLayout from '../layouts/admin/admin-layout.astro'
import PageHeader from '../components/common/page-header.astro'
import { getPathPrefix } from '../../utils/path.js'

const pageHeaderProps = {
  title: 'Analytics Dashboard',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Analytics', class: 'active' }
  ]
}
---

<AdminLayout
  title="Analytics Dashboard"
  description="RSS and article analytics dashboard showing feed metrics, crawl activity, and content statistics"
  currentPath="analytics"
>
  <PageHeader {...pageHeaderProps} />
  <div class="row">
    <div class="col">
      <!-- Loading State -->
      <div id="analyticsLoadingState" class="text-center py-5" style="display:none;">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading analytics data...</p>
      </div>

      <!-- Error State -->
      <div id="analyticsErrorState" class="alert alert-danger" role="alert" style="display:none;">
        Failed to load analytics data.
      </div>

      <!-- Key Performance Metrics -->
      <div class="row mb-4">
        <div class="col-lg-3">
          <div class="info-box info-box-outline info-box-outline-primary">
            <div class="info-box-icon bg-primary">
              <i class="ri-article-line"></i>
            </div>
            <div class="info-box-content">
              <span class="info-box-text">Total Article Scrap</span>
              <span class="info-box-number" id="analytics-total-article-scrap">—</span>
              <div class="info-box-trend" id="analytics-total-article-scrap-trend">Loading...</div>
            </div>
          </div>
        </div>
        <div class="col-lg-3">
          <div class="info-box info-box-outline info-box-outline-success">
            <div class="info-box-icon bg-success">
              <i class="ri-add-circle-line"></i>
            </div>
            <div class="info-box-content">
              <span class="info-box-text">New Articles This Week</span>
              <span class="info-box-number" id="analytics-new-articles-week">—</span>
              <div class="info-box-trend" id="analytics-new-articles-week-trend">Loading...</div>
            </div>
          </div>
        </div>
        <div class="col-lg-3">
          <div class="info-box info-box-outline info-box-outline-warning">
            <div class="info-box-icon bg-warning">
              <i class="ri-time-line"></i>
            </div>
            <div class="info-box-content">
              <span class="info-box-text">Median Feed Update Time</span>
              <span class="info-box-number" id="analytics-median-feed-update">—</span>
              <div class="info-box-trend" id="analytics-median-feed-update-trend">Loading...</div>
            </div>
          </div>
        </div>
        <div class="col-lg-3">
          <div class="info-box info-box-outline info-box-outline-info">
            <div class="info-box-icon bg-info">
              <i class="ri-file-text-line"></i>
            </div>
            <div class="info-box-content">
              <span class="info-box-text">Median Article Word Count</span>
              <span class="info-box-number" id="analytics-median-word-count">—</span>
              <div class="info-box-trend" id="analytics-median-word-count-trend">Loading...</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Articles Overview and Feeds Distribution -->
      <div class="row mb-4">
        <div class="col-md-8">
          <div class="card h-100">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="card-title mb-0">Articles Counts Overview</h5>
                <div class="text-muted small">Daily new articles by feed source</div>
              </div>
              <div
                class="chart"
                id="articlesCountsChart"
                data-chart-type="bar"
                data-chart-stacked="true"
                data-chart-data="{}"
                style="height:320px;width:100%"
              >
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-4 mt-4 mt-md-0">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title">Monthly Feeds Distribution</h5>
              <div
                class="chart"
                id="feedsDistributionChart"
                data-chart-type="doughnut"
                data-chart-data="{}"
                style="height:330px;width:100%"
              >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Traffic Metrics Overview -->
      <div class="row mb-4">
        <div class="col-md-3">
          <div class="card h-100">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="card-title mb-0">Traffic Metrics</h5>
              </div>

              <div class="mb-4">
                <div class="small text-muted mb-1">RSS Query Traffic</div>
                <div class="d-flex align-items-center gap-2">
                  <h3 class="mb-0" id="rssQueryTotal">—</h3>
                  <span class="badge bg-primary-subtle text-primary">queries</span>
                </div>
                <div
                  class="chart"
                  id="rssQueryMetricChart"
                  data-chart-type="line"
                  data-chart-data="{}"
                  style="height:50px;width:100%"
                >
                </div>
              </div>

              <div>
                <div class="small text-muted mb-1">Article Scrap Traffic</div>
                <div class="d-flex align-items-center gap-2">
                  <h3 class="mb-0">
                    <span id="articleScrapSuccessTotal">—</span> / <span
                      id="articleScrapFailTotal"
                      class="text-danger">—</span
                    >
                  </h3>
                  <span class="badge bg-success-subtle text-success">ok/fail</span>
                </div>
                <div
                  class="chart"
                  id="articleScrapMetricChart"
                  data-chart-type="line"
                  data-chart-data="{}"
                  style="height:50px;width:100%"
                >
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-9 mt-4 mt-md-0">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title">Articles Growth Trends</h5>
              <div
                class="chart"
                id="articleGrowthChart"
                data-chart-type="line"
                data-chart-data="{}"
                style="height:300px;width:100%"
              >
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row mb-4">
        <!-- Real-time Scrap Activity -->
        <div class="col-12">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title">Real-time Scrap Activity</h5>
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Feed Name</th>
                      <th>Article Title</th>
                      <th>Update Time</th>
                      <th>Word Count</th>
                      <th>Ori URL</th>
                    </tr>
                  </thead>
                  <tbody id="latestArticlesTableBody">
                    <tr>
                      <td colspan="5" class="text-muted text-center">Loading...</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============================================================
           PRESERVED PANELS: The following two panels are kept as-is
           from the AdminLTE demo and are NOT part of the analytics
           data alignment scope.
           ============================================================ -->

      <div class="row mb-4">
        <div class="col-xl-8">
          <div class="card h-100">
            <div class="card-header">
              <ul class="nav nav-pills p-2">
                <li class="nav-item">
                  <a class="nav-link active" id="osTab" data-bs-toggle="pill" href="#osContent"
                    >Operating Systems</a
                  >
                </li>
                <li class="nav-item">
                  <a class="nav-link" id="browserTab" data-bs-toggle="pill" href="#browserContent"
                    >Web Browsers</a
                  >
                </li>
                <li class="nav-item">
                  <a class="nav-link" id="devicesTab" data-bs-toggle="pill" href="#devicesContent"
                    >Device Types</a
                  >
                </li>
              </ul>
            </div>
            <div class="card-body">
              <div class="tab-content">
                <div class="tab-pane fade show active" id="osContent">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>Rank</th>
                        <th>Operating System</th>
                        <th>Total Visits</th>
                        <th>Market Share</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>1</td>
                        <td><i class="ri-windows-fill fs-5 me-2"></i> Windows</td>
                        <td>1,245,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 33%;"
                              role="progressbar"
                              aria-valuenow="33"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>2</td>
                        <td><i class="ri-apple-fill fs-5 me-2"></i> macOS</td>
                        <td>820,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 22%;"
                              role="progressbar"
                              aria-valuenow="22"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>3</td>
                        <td><i class="ri-android-fill fs-5 me-2"></i> Android</td>
                        <td>1,590,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 43%;"
                              role="progressbar"
                              aria-valuenow="43"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>4</td>
                        <td><i class="ri-ubuntu-fill fs-5 me-2"></i> Ubuntu</td>
                        <td>250,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 6%;"
                              role="progressbar"
                              aria-valuenow="6"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <div class="tab-pane fade" id="browserContent">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>Rank</th>
                        <th>Web Browser</th>
                        <th>Total Visits</th>
                        <th>Market Share</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>1</td>
                        <td><i class="ri-google-fill fs-5 me-2"></i> Google Chrome</td>
                        <td>2,340,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 50%;"
                              role="progressbar"
                              aria-valuenow="50"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>2</td>
                        <td><i class="ri-firefox-fill fs-5 me-2"></i> Mozilla Firefox</td>
                        <td>1,120,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 25%;"
                              role="progressbar"
                              aria-valuenow="25"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>3</td>
                        <td><i class="ri-safari-fill fs-5 me-2"></i> Safari</td>
                        <td>780,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 17%;"
                              role="progressbar"
                              aria-valuenow="17"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>4</td>
                        <td><i class="ri-edge-fill fs-5 me-2"></i> Microsoft Edge</td>
                        <td>540,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 8%;"
                              role="progressbar"
                              aria-valuenow="8"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <div class="tab-pane fade" id="devicesContent">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>Rank</th>
                        <th>Device Category</th>
                        <th>Total Visits</th>
                        <th>Market Share</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>1</td>
                        <td><i class="ri-smartphone-line fs-5 me-2"></i> Mobile Devices</td>
                        <td>5,000,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 60%;"
                              role="progressbar"
                              aria-valuenow="60"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>2</td>
                        <td><i class="ri-computer-line fs-5 me-2"></i> Desktop Computers</td>
                        <td>2,500,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 30%;"
                              role="progressbar"
                              aria-valuenow="30"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>3</td>
                        <td><i class="ri-tablet-line fs-5 me-2"></i> Tablet Devices</td>
                        <td>500,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 10%;"
                              role="progressbar"
                              aria-valuenow="10"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td>4</td>
                        <td><i class="ri-tv-2-line fs-5 me-2"></i> Smart TVs</td>
                        <td>50,000</td>
                        <td>
                          <div class="progress">
                            <div
                              class="progress-bar progress-bar-striped progress-bar-animated"
                              style="width: 4%;"
                              role="progressbar"
                              aria-valuenow="4"
                              aria-valuemin="0"
                              aria-valuemax="100"
                            >
                            </div>
                          </div>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="col-xl-4 mt-4 mt-xl-0">
          <div class="card h-100">
            <div class="card-header">
              <h5 class="card-title mb-0 mt-2">Device Traffic Summary</h5>
            </div>
            <div class="card-body d-flex p-4">
              <div class="row g-2">
                <div class="col-6">
                  <div class="card shadow-sm rounded-2">
                    <div class="card-body">
                      <div class="d-flex flex-column align-items-center justify-content-center">
                        <div class="bg-primary bg-opacity-10 rounded-2 px-2 py-0 mb-2">
                          <i class="ri-smartphone-line fs-3 text-primary"></i>
                        </div>
                        <span class="fw-bold fs-5">5,000,000</span>
                        <span class="text-muted">Mobile Traffic</span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-6">
                  <div class="card">
                    <div class="card-body">
                      <div class="d-flex flex-column align-items-center justify-content-center">
                        <div class="bg-primary bg-opacity-10 rounded-2 px-2 py-0 mb-2">
                          <i class="ri-computer-line fs-3 text-primary"></i>
                        </div>
                        <span class="fw-bold fs-5">2,500,000</span>
                        <span class="text-muted">Desktop Traffic</span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-6">
                  <div class="card">
                    <div class="card-body">
                      <div class="d-flex flex-column align-items-center justify-content-center">
                        <div class="bg-primary bg-opacity-10 rounded-2 px-2 py-0 mb-2">
                          <i class="ri-tablet-line fs-3 text-primary"></i>
                        </div>
                        <span class="fw-bold fs-5">500,000</span>
                        <span class="text-muted">Tablet Traffic</span>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-6">
                  <div class="card">
                    <div class="card-body">
                      <div class="d-flex flex-column align-items-center justify-content-center">
                        <div class="bg-primary bg-opacity-10 rounded-2 px-2 py-0 mb-2">
                          <i class="ri-tv-2-line fs-3 text-primary"></i>
                        </div>
                        <span class="fw-bold fs-5">50,000</span>
                        <span class="text-muted">TV Traffic</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { initAnalytics } from '@/scripts/analytics'

  document.addEventListener('astro:page-load', () => initAnalytics())
</script>
