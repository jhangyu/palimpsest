---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import { getPathPrefix } from '../../../utils/path.js'

const pageHeaderConfig = {
  title: 'User Management',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Settings', href: getPathPrefix('/settings') },
    { label: 'User Management', class: 'active' }
  ]
}
---

<AdminLayout
  title="User Management"
  description="Manage and monitor user accounts"
  currentPath="settings/users"
>
  <PageHeader {...pageHeaderConfig} />

  <h5 class="mb-3"><i class="ri-user-add-line me-2"></i>Add User</h5>

  <!-- Success banner (hidden by default) -->
  <div id="add-user-success" class="alert alert-success mb-4" style="display:none;" role="alert">
    <i class="ri-user-add-line me-2"></i>
    <strong>User created.</strong> An invite link has been sent to their email address so they can set
    their password.
  </div>

  <form id="add-user-form" class="row g-4 mb-4" novalidate>
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <div class="d-flex align-items-center">
            <i class="ri-user-add-line me-2"></i>
            <h5 class="card-title mb-0">User Information</h5>
          </div>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label required" for="add-user-email">Email Address</label>
            <input
              type="email"
              class="form-control"
              id="add-user-email"
              placeholder="user@example.com"
              autocomplete="off"
              required
            />
            <div class="form-text">
              <i class="ri-mail-send-line me-1"></i>
              An invite link will be sent to this address for the user to set their password.
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label required" for="add-user-username">Username</label>
            <div class="input-group">
              <span class="input-group-text"><i class="ri-at-line"></i></span>
              <input
                type="text"
                class="form-control"
                id="add-user-username"
                placeholder="lowercase letters only, 1-20 chars"
                maxlength="20"
                pattern="[a-z]{1,20}"
                required
              />
            </div>
            <div class="form-text">Lowercase English letters only (a-z), 1-20 characters.</div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="add-user-full-name">Full Name</label>
            <input
              type="text"
              class="form-control"
              id="add-user-full-name"
              placeholder="Optional"
              autocomplete="off"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card">
        <div class="card-header">
          <div class="d-flex align-items-center">
            <i class="ri-shield-keyhole-line me-2"></i>
            <h5 class="card-title mb-0">Roles</h5>
          </div>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">
            Assign one or more roles. A user with no role will default to the standard "user" role.
          </p>
          <div class="mb-2">
            <div class="form-check">
              <input
                class="form-check-input"
                type="checkbox"
                name="role"
                id="role-admin"
                value="admin"
              />
              <label class="form-check-label" for="role-admin">
                <span class="fw-semibold"><i class="ri-admin-line me-1"></i>Administrator</span>
                <span class="d-block text-muted small">Full system access, user management</span>
              </label>
            </div>
          </div>
          <div class="mb-2">
            <div class="form-check">
              <input
                class="form-check-input"
                type="checkbox"
                name="role"
                id="role-user"
                value="user"
                checked
              />
              <label class="form-check-label" for="role-user">
                <span class="fw-semibold"><i class="ri-user-line me-1"></i>User</span>
                <span class="d-block text-muted small"
                  >Standard access to feeds, articles, analytics</span
                >
              </label>
            </div>
          </div>
        </div>
        <div class="card-footer d-flex justify-content-end">
          <button type="submit" class="btn btn-primary">
            <i class="ri-user-add-line me-1"></i>Create User
          </button>
        </div>
      </div>

      <div class="card mt-3">
        <div class="card-body">
          <div class="d-flex gap-2">
            <i class="ri-information-line text-primary mt-1"></i>
            <p class="text-muted small mb-0">
              Admin cannot set a password for the new user. An invite link will be sent so the user
              can set their own password securely.
            </p>
          </div>
        </div>
      </div>
    </div>
  </form>

  <hr class="my-4" />

  <h5 class="mb-3"><i class="ri-list-check me-2"></i>User List</h5>

  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div class="search-wrapper" style="min-width:260px;">
            <i class="ri-search-line search-icon"></i>
            <input
              type="text"
              class="form-control search-input"
              id="user-search-input"
              placeholder="Search by username or email..."
            />
          </div>
        </div>
        <div class="card-body p-0">
          <div id="user-list-container" class="p-3">
            <div class="text-center py-5">
              <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { initAddUserPage, initUserListPage } from '@/scripts/users'

  const init = () => {
    initAddUserPage()
    initUserListPage()
  }

  document.addEventListener('astro:page-load', init)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init)
  } else {
    init()
  }
</script>
