---
// ---
// name: feeds-edit
// description: "Feed editor: feed management table with inline detail editor for URL, name, refresh frequency, AI list/content rule generation, article filter builder, and live crawl preview"
// type: page
// target:
//   layer: frontend
//   domain: feeds
// spec_doc: null
// test_file: tests/stage2/e2e/stage2/feeds.spec.ts
// route: /feeds/edit
// ---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'
import FeedRulesEditor from '../../components/feeds/FeedRulesEditor.astro'

const headerProps = {
  title: 'Feed Editor',
  breadcrumbs: [
    { label: 'Dashboard', href: '/dashboard' },
    { label: 'Feeds', href: '/feeds/edit' },
    { label: 'Edit', class: 'active' }
  ]
}
---

<AdminLayout
  currentPath="feeds/edit"
  title="Feed Editor"
  description="Manage and configure RSS feed sources"
>
  <PageHeader {...headerProps} />

  <div id="feed-edit-root">
    <!-- ================================================================= -->
    <!-- Section 1: Feed Management Table                                  -->
    <!-- ================================================================= -->
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Feed Management</h5>
        <button id="btn-refresh-table" class="btn btn-sm btn-outline-secondary" type="button">
          <i class="ri-refresh-line me-1"></i> Refresh Table
        </button>
      </div>
      <div class="card-body p-0">
        <!-- Loading spinner -->
        <div id="feed-table-loading" class="text-center py-5 text-muted">
          <span
            class="spinner-border spinner-border-sm mb-2 d-block mx-auto"
            style="width:1.5rem;height:1.5rem;"
            role="status"></span>
          Loading feeds...
        </div>
        <!-- Table -->
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Feed Name</th>
                <th>Target URL</th>
                <th>Refresh</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="feed-table-body"> </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ================================================================= -->
    <!-- Section 2: Detail Editor (hidden until a feed is selected)        -->
    <!-- ================================================================= -->
    <div id="editor-section" class="card mb-4 d-none">
      <div class="card-header">
        <h5 class="card-title mb-0 d-flex align-items-center gap-2">
          <i class="ri-pencil-line"></i>
          <span id="editor-title">Editing</span>
        </h5>
      </div>
      <div class="card-body">
        <div class="row">
          <!-- Left column: form -->
          <div class="col-12" id="editor-form-col">
            <!-- URL -->
            <div class="mb-3">
              <label for="input-url" class="form-label">Target Website URL / RSS</label>
              <div class="d-flex align-items-center">
                <input
                  id="input-url"
                  type="text"
                  class="form-control"
                  placeholder="https://example.com"
                />
                <div id="source-type-toggle" class="btn-group btn-group-sm ms-2" role="group">
                  <button
                    type="button"
                    id="source-type-html"
                    class="btn btn-outline-secondary active">HTML</button
                  >
                  <button type="button" id="source-type-rss" class="btn btn-outline-secondary"
                    >RSS</button
                  >
                </div>
              </div>
            </div>

            <!-- Name -->
            <div class="mb-3">
              <label for="input-name" class="form-label">Site Name</label>
              <input id="input-name" type="text" class="form-control" />
            </div>

            <!-- Refresh Frequency -->
            <div class="mb-3 d-flex align-items-center gap-3">
              <label for="input-freq" class="form-label mb-0">Refresh Frequency (minutes)</label>
              <input
                id="input-freq"
                type="number"
                class="form-control"
                style="width:100px"
                min="5"
                max="1440"
              />
              <small class="text-muted">Range: 5 - 1440 (1 day)</small>
            </div>

            <hr />

            <FeedRulesEditor>
              <div slot="after-rules">
                <hr />
                <div class="mb-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label mb-0">3. Article Filter (White/Black List)</label>
                  </div>
                  <div id="filter-builder-root"></div>
                </div>
              </div>
            </FeedRulesEditor>

            <!-- Footer: Save / Crawl / Debug -->
            <div class="d-flex align-items-center gap-3">
              <button id="btn-save" class="btn btn-success flex-grow-1" type="button">
                <i class="ri-save-line me-1"></i> Save Changes
              </button>
              <button
                id="btn-crawl-editor"
                class="btn btn-dark"
                type="button"
                title="Trigger Crawl"
              >
                <i class="ri-play-line"></i>
              </button>
              <button
                id="btn-force-refresh"
                class="btn btn-warning"
                type="button"
                title="Force Refresh"
              >
                <i class="ri-loop-left-line"></i>
              </button>
              <label
                id="debug-label"
                class="d-flex align-items-center gap-1 text-muted"
                style="cursor:pointer"
                title="Enable debug mode to save intermediate artifacts"
              >
                <i class="ri-bug-line"></i>
                <small>Debug</small>
                <div class="form-check form-switch mb-0 ms-1">
                  <input
                    id="debug-checkbox"
                    class="form-check-input"
                    type="checkbox"
                    role="switch"
                  />
                </div>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================================= -->
    <!-- Section 3: Preview Table (hidden until tests are run)             -->
    <!-- ================================================================= -->
    <div id="preview-section" class="card mb-4 d-none">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Live Crawl Preview</h5>
        <div class="d-flex gap-2">
          <button
            id="btn-filter-preview"
            class="btn btn-sm btn-outline-secondary"
            type="button"
            title="Toggle filter effect visibility in preview"
          >
            <i class="ri-filter-line me-1"></i>Preview Filter
          </button>
          <button id="btn-test-both" class="btn btn-sm btn-primary" type="button">
            <i class="ri-play-circle-line me-1"></i> Test Both List &amp; Content Crawl
          </button>
        </div>
      </div>
      <div class="card-body" id="preview-body"></div>
    </div>
    <!-- ================================================================= -->
    <!-- Force Refresh Scope Modal                                        -->
    <!-- ================================================================= -->
    <div
      class="modal fade"
      id="forceRefreshModal"
      tabindex="-1"
      aria-labelledby="forceRefreshModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="forceRefreshModalLabel">
              <i class="ri-loop-left-line me-1"></i>Force Refresh
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <p class="text-muted mb-3">
              Re-crawl and overwrite existing article content in the database. Articles with empty
              content after scraping will be skipped.
            </p>
            <div class="form-check mb-2">
              <input
                class="form-check-input"
                type="radio"
                name="forceRefreshScope"
                id="scopeCurrent"
                value="current"
                checked
              />
              <label class="form-check-label" for="scopeCurrent">
                <strong>Current list / RSS</strong> &mdash; Re-crawl articles from the current feed source
                (recommended)
              </label>
            </div>
            <div class="form-check">
              <input
                class="form-check-input"
                type="radio"
                name="forceRefreshScope"
                id="scopeAllDb"
                value="all_db"
              />
              <label class="form-check-label" for="scopeAllDb">
                <strong>All articles in DB</strong> &mdash; Re-crawl every stored article (may be slow,
                use with caution)
              </label>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" id="btn-force-refresh-confirm" class="btn btn-warning">
              <i class="ri-loop-left-line me-1"></i>Start Force Refresh
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<style is:global>
  .filter-group {
    border-left: 3px solid var(--bs-primary);
    padding-left: 1rem;
    margin-left: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .filter-group[data-operator='or'] {
    border-left-color: var(--bs-warning);
  }
  .filter-group .filter-group {
    margin-top: 0.5rem;
  }

  /* Selected feed row — dark mode fix */
  [data-bs-theme='dark'] .table .table-active {
    --bs-table-active-bg: var(--bs-tertiary-bg);
  }
</style>

<script>
  import { initFeedEdit } from '@/scripts/feed-edit'
  document.addEventListener('astro:page-load', () => initFeedEdit())
</script>
