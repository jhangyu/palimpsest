---
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'

const headerProps = {
  title: 'Feed Editor',
  breadcrumbs: [
    { label: 'Dashboard', href: '/dashboard' },
    { label: 'Feeds', href: '/feeds/edit' },
    { label: 'Edit', class: 'active' }
  ]
}
---

<AdminLayout
  currentPath="feeds/edit"
  title="Feed Editor"
  description="Manage and configure RSS feed sources"
>
  <PageHeader {...headerProps} />

  <div id="feed-edit-root">
    <!-- ================================================================= -->
    <!-- Section 1: Feed Management Table                                  -->
    <!-- ================================================================= -->
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Feed Management</h5>
        <button id="btn-refresh-table" class="btn btn-sm btn-outline-secondary" type="button">
          <i class="ri-refresh-line me-1"></i> Refresh Table
        </button>
      </div>
      <div class="card-body p-0">
        <!-- Loading spinner -->
        <div id="feed-table-loading" class="text-center py-5 text-muted">
          <span
            class="spinner-border spinner-border-sm mb-2 d-block mx-auto"
            style="width:1.5rem;height:1.5rem;"
            role="status"></span>
          Loading feeds...
        </div>
        <!-- Table -->
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Feed Name</th>
                <th>Target URL</th>
                <th>Refresh</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="feed-table-body"> </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ================================================================= -->
    <!-- Section 2: Detail Editor (hidden until a feed is selected)        -->
    <!-- ================================================================= -->
    <div id="editor-section" class="card mb-4 d-none">
      <div class="card-header">
        <h5 class="card-title mb-0 d-flex align-items-center gap-2">
          <i class="ri-pencil-line"></i>
          <span id="editor-title">Editing</span>
        </h5>
      </div>
      <div class="card-body">
        <div class="row">
          <!-- Left column: form -->
          <div class="col-12" id="editor-form-col">
            <!-- URL -->
            <div class="mb-3">
              <label for="input-url" class="form-label">Target Website URL</label>
              <input
                id="input-url"
                type="text"
                class="form-control"
                placeholder="https://example.com"
              />
            </div>

            <!-- Name -->
            <div class="mb-3">
              <label for="input-name" class="form-label">Site Name</label>
              <input id="input-name" type="text" class="form-control" />
            </div>

            <!-- Refresh Frequency -->
            <div class="mb-3 d-flex align-items-center gap-3">
              <label for="input-freq" class="form-label mb-0">Refresh Frequency (minutes)</label>
              <input
                id="input-freq"
                type="number"
                class="form-control"
                style="width:100px"
                min="5"
                max="1440"
              />
              <small class="text-muted">Range: 5 - 1440 (1 day)</small>
            </div>

            <hr />

            <!-- AI Analysis: List Rules -->
            <div class="mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <label class="form-label mb-0">1. List Rules (AI Generation)</label>
                <div class="d-flex gap-2">
                  <button
                    id="btn-test-list"
                    class="btn btn-sm btn-outline-secondary"
                    type="button"
                    title="Test only list extraction"
                  >
                    <i class="ri-file-list-line me-1"></i> Test List
                  </button>
                  <button id="btn-analyze-list" class="btn btn-sm btn-primary" type="button">
                    <i class="ri-brain-line me-1"></i> Analyze List
                  </button>
                </div>
              </div>
            </div>

            <!-- AI Analysis: Content Rules -->
            <div class="mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <label class="form-label mb-0">2. Content Rules (AI Generation)</label>
                <div class="d-flex gap-2">
                  <button
                    id="btn-test-content"
                    class="btn btn-sm btn-outline-secondary"
                    type="button"
                    title="Test content extraction with sample URL"
                  >
                    <i class="ri-article-line me-1"></i> Test Content
                  </button>
                  <button id="btn-analyze-content" class="btn btn-sm btn-primary" type="button">
                    <i class="ri-brain-line me-1"></i> Analyze Content
                  </button>
                </div>
              </div>
              <input
                id="input-sample-url"
                type="text"
                class="form-control form-control-sm"
                placeholder="Sample Article URL for testing"
              />
            </div>

            <!-- Toggle Rules JSON -->
            <div class="d-flex justify-content-end mb-3">
              <button id="btn-toggle-rules" class="btn btn-sm btn-outline-secondary" type="button">
                <i class="ri-code-line me-1"></i> Hide Rules
              </button>
            </div>

            <!-- Rules JSON Panel -->
            <div id="rules-panel" class="mb-3">
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="cm-list-rules" class="form-label">List Rules JSON</label>
                  <div id="cm-list-rules" class="border rounded" style="min-height:200px"></div>
                </div>
                <div class="col-md-6">
                  <label for="cm-content-rules" class="form-label">Content Rules JSON</label>
                  <div id="cm-content-rules" class="border rounded" style="min-height:200px"></div>
                </div>
              </div>
            </div>

            <hr />
            <div class="mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <label class="form-label mb-0">3. Article Filter (White/Black List)</label>
              </div>
              <div id="filter-builder-root"></div>
            </div>

            <!-- Footer: Save / Crawl / Debug -->
            <div class="d-flex align-items-center gap-3">
              <button id="btn-save" class="btn btn-success flex-grow-1" type="button">
                <i class="ri-save-line me-1"></i> Save Changes
              </button>
              <button
                id="btn-crawl-editor"
                class="btn btn-dark"
                type="button"
                title="Trigger Crawl"
              >
                <i class="ri-play-line"></i>
              </button>
              <label
                id="debug-label"
                class="d-flex align-items-center gap-1 text-muted"
                style="cursor:pointer"
                title="Enable debug mode to save intermediate artifacts"
              >
                <i class="ri-bug-line"></i>
                <small>Debug</small>
                <div class="form-check form-switch mb-0 ms-1">
                  <input
                    id="debug-checkbox"
                    class="form-check-input"
                    type="checkbox"
                    role="switch"
                  />
                </div>
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================================= -->
    <!-- Section 3: Preview Table (hidden until tests are run)             -->
    <!-- ================================================================= -->
    <div id="preview-section" class="card mb-4 d-none">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Live Crawl Preview</h5>
        <div class="d-flex gap-2">
          <button
            id="btn-filter-preview"
            class="btn btn-sm btn-outline-secondary"
            type="button"
            title="Toggle filter effect visibility in preview"
          >
            <i class="ri-filter-line me-1"></i>Preview Filter
          </button>
          <button id="btn-test-both" class="btn btn-sm btn-primary" type="button">
            <i class="ri-play-circle-line me-1"></i> Test Both List &amp; Content Crawl
          </button>
        </div>
      </div>
      <div class="card-body" id="preview-body"></div>
    </div>
  </div>
</AdminLayout>

<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/codemirror.min.css"
/>

<style is:global>
  .filter-group {
    border-left: 3px solid var(--bs-primary);
    padding-left: 1rem;
    margin-left: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .filter-group[data-operator='or'] {
    border-left-color: var(--bs-warning);
  }
  .filter-group .filter-group {
    margin-top: 0.5rem;
  }

  /* Selected feed row — dark mode fix */
  [data-bs-theme='dark'] .table .table-active {
    --bs-table-active-bg: var(--bs-tertiary-bg);
  }

  /* CodeMirror JSON editor — theme-aware base */
  #cm-list-rules .CodeMirror,
  #cm-content-rules .CodeMirror {
    background-color: var(--bs-body-bg);
    color: var(--bs-body-color);
  }
  #cm-list-rules .CodeMirror-gutters,
  #cm-content-rules .CodeMirror-gutters {
    background-color: var(--bs-tertiary-bg);
    border-right-color: var(--bs-border-color);
  }
  #cm-list-rules .CodeMirror-linenumber,
  #cm-content-rules .CodeMirror-linenumber {
    color: var(--bs-secondary-color);
  }
  #cm-list-rules .CodeMirror-cursor,
  #cm-content-rules .CodeMirror-cursor {
    border-left-color: var(--bs-body-color);
  }
  #cm-list-rules .CodeMirror-selected,
  #cm-content-rules .CodeMirror-selected {
    background-color: var(--bs-primary-bg-subtle);
  }

  /* JSON token colors — light mode */
  #cm-list-rules .cm-string,
  #cm-content-rules .cm-string {
    color: #0a3069;
  }
  #cm-list-rules .cm-string.cm-property,
  #cm-content-rules .cm-string.cm-property {
    color: #0550ae;
  }
  #cm-list-rules .cm-number,
  #cm-content-rules .cm-number {
    color: #0550ae;
  }
  #cm-list-rules .cm-atom,
  #cm-content-rules .cm-atom {
    color: #cf222e;
  }
  #cm-list-rules .CodeMirror-matchingbracket,
  #cm-content-rules .CodeMirror-matchingbracket {
    color: #1a7f37;
    font-weight: bold;
  }

  /* JSON token colors — dark mode */
  [data-bs-theme='dark'] #cm-list-rules .cm-string,
  [data-bs-theme='dark'] #cm-content-rules .cm-string {
    color: #a5d6ff;
  }
  [data-bs-theme='dark'] #cm-list-rules .cm-string.cm-property,
  [data-bs-theme='dark'] #cm-content-rules .cm-string.cm-property {
    color: #79c0ff;
  }
  [data-bs-theme='dark'] #cm-list-rules .cm-number,
  [data-bs-theme='dark'] #cm-content-rules .cm-number {
    color: #79c0ff;
  }
  [data-bs-theme='dark'] #cm-list-rules .cm-atom,
  [data-bs-theme='dark'] #cm-content-rules .cm-atom {
    color: #ff7b72;
  }
  [data-bs-theme='dark'] #cm-list-rules .CodeMirror-matchingbracket,
  [data-bs-theme='dark'] #cm-content-rules .CodeMirror-matchingbracket {
    color: #7ee787;
    font-weight: bold;
  }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/codemirror.min.js"
></script>
<script
  is:inline
  src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/6.65.7/mode/javascript/javascript.min.js"
></script>

<script>
  import { initFeedEdit } from '@/scripts/feed-edit'
  document.addEventListener('astro:page-load', () => initFeedEdit())
</script>
