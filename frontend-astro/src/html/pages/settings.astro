---
// ---
// name: settings
// description: "System settings page: tabbed navigation for system basics, crawler defaults, maintenance/retention, and web notification preferences"
// type: page
// target:
//   layer: frontend
//   domain: settings
// spec_doc: null
// test_file: null
// route: /settings
// ---
import AdminLayout from '../layouts/admin/admin-layout.astro'
import PageHeader from '../components/common/page-header.astro'
import { getPathPrefix } from '../../utils/path.js'

// Configuration for the page header with title and breadcrumb navigation
const settingsPageHeader = {
  title: 'System Settings',
  backLink: '',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'System Settings', class: 'active' }
  ]
}

// Client-side JavaScript for form validation, tab navigation, and AI tokens
const _settingsApiBase = import.meta.env.DEV ? 'http://localhost:8088' : ''
const settingsPageScript = `
<script>
  var _SETTINGS_API_BASE = '${_settingsApiBase}';
  function setupSettingsPage() {
    const settingsRoot = document.querySelector('[data-settings-page-root]');
    if (!settingsRoot || settingsRoot.dataset.settingsPageBound === 'true') return;
    settingsRoot.dataset.settingsPageBound = 'true';

    // Initialize Bootstrap form validation (placeholder forms — always prevent default)
    const settingsForms = document.querySelectorAll('.needs-validation');
    Array.from(settingsForms).forEach(form => {
      form.addEventListener('submit', event => {
        event.preventDefault();
        event.stopPropagation();
        form.classList.add('was-validated');
      }, false);
    });

    // Custom tab navigation implementation
    const tabElements = document.querySelectorAll('[data-bs-toggle="tab"]');
    tabElements.forEach(tabElement => {
      tabElement.addEventListener('click', event => {
        event.preventDefault();
        const targetId = event.currentTarget.getAttribute('href');
        const targetPane = document.querySelector(targetId);
        if (!targetPane) return;
        const tabContainer = targetPane.closest('.tab-content');
        const currentActiveTab = tabContainer.querySelector('.tab-pane.show.active');

        // Toggle tab visibility
        if (currentActiveTab) currentActiveTab.classList.remove('show', 'active');
        targetPane.classList.add('show', 'active');

        // Update navigation menu active state
        event.currentTarget.closest('.nav-tree')?.querySelectorAll('.nav-item').forEach(navItem => {
          navItem.classList.remove('active');
        });
        event.currentTarget.closest('.nav-item').classList.add('active');

      });
    });

    // Notification preferences
    const notifSection = document.getElementById('notifications-section');
    if (notifSection) {
      // Load saved preferences
      fetch(_SETTINGS_API_BASE + '/users/me', { credentials: 'include' })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (!data) return;
          const prefs = data.preferences?.notifications || {};
          const types = ['fail_crawl', 'ai_reanalyze', 'fail_access'];
          types.forEach(t => {
            const el = document.querySelector('[data-notification-type="' + t + '"]');
            if (el) el.checked = prefs[t] !== false; // default to true
          });
        })
        .catch(() => {});

      // Save button
      const saveBtn = document.getElementById('btn-save-notifications');
      if (saveBtn) {
        saveBtn.addEventListener('click', () => {
          const types = ['fail_crawl', 'ai_reanalyze', 'fail_access'];
          const notifications = {};
          types.forEach(t => {
            const el = document.querySelector('[data-notification-type="' + t + '"]');
            notifications[t] = el ? el.checked : true;
          });

          // Get CSRF token from cookie (double-submit pattern)
          const csrfCookie = document.cookie.split('; ').find(r => r.startsWith('csrf_token='));
          const headers = { 'Content-Type': 'application/json' };
          if (csrfCookie) headers['X-CSRF-Token'] = decodeURIComponent(csrfCookie.split('=')[1]);

          // First GET current preferences, then merge and PUT
          fetch(_SETTINGS_API_BASE + '/users/me', { credentials: 'include' })
            .then(r => r.ok ? r.json() : null)
            .then(data => {
              const existingPrefs = (data && data.preferences) ? data.preferences : {};
              const mergedPrefs = Object.assign({}, existingPrefs, { notifications });

              return fetch(_SETTINGS_API_BASE + '/users/me/preferences', {
                method: 'PUT',
                credentials: 'include',
                headers,
                body: JSON.stringify({ preferences: mergedPrefs })
              });
            })
            .then(r => {
              if (r && r.ok) {
                saveBtn.innerHTML = '<i class="ri-check-line me-1"></i> Saved';
                setTimeout(() => {
                  saveBtn.innerHTML = '<i class="ri-save-3-line me-1"></i> Save Changes';
                }, 2000);
              }
            })
            .catch(() => {});
        });
      }
    }
  }

  document.addEventListener('astro:page-load', setupSettingsPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupSettingsPage);
  } else {
    setupSettingsPage();
  }
</script>
`
---

<AdminLayout
  title="System Settings"
  description="Manage your system configuration and preferences"
  currentPath="settings"
  pageScript={settingsPageScript}
>
  <PageHeader {...settingsPageHeader} />

  <div class="row g-4" data-settings-page-root>
    <!-- Settings Navigation Menu -->
    <div class="col-lg-3">
      <div class="card p-3">
        <div class="card-body">
          <nav class="nav-tree">
            <ul class="list-unstyled">
              <li class="nav-section">
                <span class="nav-section-text text-uppercase px-2">Configuration</span>
              </li>
              <li class="nav-item active">
                <a class="nav-link" href="#system-section" data-bs-toggle="tab">
                  <i class="ri-settings-4-line"></i>
                  <span>System Basics</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#crawler-section" data-bs-toggle="tab">
                  <i class="ri-robot-line"></i>
                  <span>Crawler Defaults</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#maintenance-section" data-bs-toggle="tab">
                  <i class="ri-database-2-line"></i>
                  <span>Maintenance</span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#notifications-section" data-bs-toggle="tab">
                  <i class="ri-notification-4-line"></i>
                  <span>Notifications</span>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>

    <!-- Settings Forms Container -->
    <div class="col-lg-9">
      <div class="tab-content">
        <!-- System Basics Panel -->
        <div class="tab-pane fade show active" id="system-section">
          <div class="card">
            <div class="card-header">
              <div class="d-flex align-items-center">
                <i class="ri-settings-4-line me-2"></i>
                <h5 class="card-title mb-0">System Basics</h5>
              </div>
            </div>
            <div class="card-body">
              <form id="system-form" class="needs-validation" novalidate>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label required">Application Name</label>
                    <input
                      type="text"
                      class="form-control"
                      placeholder="Enter application name"
                      value="Palimpsest AI Feed"
                      required
                    />
                    <div class="invalid-feedback">Application name is required</div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label required">Application Base URL</label>
                    <input
                      type="url"
                      class="form-control"
                      placeholder="https://aifeed.yourdomain.com"
                      value="https://aifeed.jhangy.us"
                      required
                    />
                    <div class="form-text">Used for generating absolute RSS feed URLs.</div>
                    <div class="invalid-feedback">
                      Please enter a valid URL (e.g., https://yourdomain.com)
                    </div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label required">System Admin Email</label>
                    <input
                      type="email"
                      class="form-control"
                      placeholder="admin@yourdomain.com"
                      value=""
                      autocomplete="email"
                      required
                    />
                    <div class="form-text">Used for system alerts and notifications.</div>
                    <div class="invalid-feedback">Please enter a valid email address</div>
                  </div>
                </div>
              </form>
            </div>
            <div class="card-footer bg-transparent d-flex justify-content-end py-3">
              <button type="submit" class="btn btn-primary" form="system-form">
                <i class="ri-save-3-line me-1"></i> Save Changes
              </button>
            </div>
          </div>
        </div>

        <!-- Crawler Defaults Panel -->
        <div class="tab-pane fade" id="crawler-section">
          <div class="card">
            <div class="card-header">
              <div class="d-flex align-items-center">
                <i class="ri-robot-line me-2"></i>
                <h5 class="card-title mb-0">Crawler & Auto-Repair Defaults</h5>
              </div>
            </div>
            <div class="card-body">
              <form id="crawler-form" class="needs-validation" novalidate>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label required">Default Refresh Frequency (minutes)</label>
                    <input type="number" class="form-control" value="60" min="5" required />
                    <div class="form-text">Global default interval for scheduled crawls.</div>
                    <div class="invalid-feedback">Please enter a valid number (minimum 5)</div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label required">Auto-Repair Global Threshold</label>
                    <input type="number" class="form-control" value="3" min="1" required />
                    <div class="form-text">
                      Consecutive structural failures before AI auto-repair (can be overridden
                      per-site).
                    </div>
                    <div class="invalid-feedback">Please enter a valid number (minimum 1)</div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label required">Max Concurrent Crawls</label>
                    <input type="number" class="form-control" value="3" min="1" required />
                    <div class="form-text">
                      System-wide semaphore limit for parallel browser sessions.
                    </div>
                    <div class="invalid-feedback">Please enter a valid number (minimum 1)</div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label required">Default Crawl Timeout (seconds)</label>
                    <input type="number" class="form-control" value="30" min="10" required />
                    <div class="form-text">Networkidle and page load timeout for crawler.</div>
                    <div class="invalid-feedback">Please enter a valid number (minimum 10)</div>
                  </div>
                </div>
              </form>
            </div>
            <div class="card-footer bg-transparent d-flex justify-content-end py-3">
              <button type="submit" class="btn btn-primary" form="crawler-form">
                <i class="ri-save-3-line me-1"></i> Save Changes
              </button>
            </div>
          </div>
        </div>

        <!-- Maintenance Panel -->
        <div class="tab-pane fade" id="maintenance-section">
          <div class="card">
            <div class="card-header">
              <div class="d-flex align-items-center">
                <i class="ri-database-2-line me-2"></i>
                <h5 class="card-title mb-0">Maintenance & Retention</h5>
              </div>
            </div>
            <div class="card-body">
              <form id="maintenance-form" class="needs-validation" novalidate>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label required">Article Retention (Days)</label>
                    <input type="number" class="form-control" value="30" min="1" required />
                    <div class="form-text">
                      How long to keep fetched articles before auto-cleanup.
                    </div>
                    <div class="invalid-feedback">Please enter a valid number (minimum 1)</div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label required">System Logs Retention (Days)</label>
                    <input type="number" class="form-control" value="14" min="1" required />
                    <div class="form-text">How long to retain system events and crawler logs.</div>
                    <div class="invalid-feedback">Please enter a valid number (minimum 1)</div>
                  </div>
                </div>
              </form>
            </div>
            <div class="card-footer bg-transparent d-flex justify-content-end py-3">
              <button type="submit" class="btn btn-primary" form="maintenance-form">
                <i class="ri-save-3-line me-1"></i> Save Changes
              </button>
            </div>
          </div>
        </div>

        <!-- Notifications Panel -->
        <div class="tab-pane fade" id="notifications-section">
          <div class="card">
            <div class="card-header">
              <div class="d-flex align-items-center">
                <i class="ri-notification-4-line me-2"></i>
                <h5 class="card-title mb-0">Web Notification Preferences</h5>
              </div>
            </div>
            <div class="card-body">
              <p class="text-muted mb-3">Select which events trigger browser notifications.</p>
              <div class="list-group">
                <div
                  class="list-group-item d-flex justify-content-between align-items-center border-0"
                >
                  <div>
                    <div class="d-flex align-items-center mb-2">
                      <i class="ri-error-warning-line me-2 text-primary"></i>
                      <span class="fw-medium">Fail Crawl</span>
                    </div>
                    <div class="text-muted">
                      Notify when a scheduled crawl fails to extract articles.
                    </div>
                  </div>
                  <div class="form-check form-switch">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="notif-fail-crawl"
                      data-notification-type="fail_crawl"
                      checked
                      title="Toggle fail crawl notifications"
                    />
                  </div>
                </div>
                <div
                  class="list-group-item d-flex justify-content-between align-items-center border-0 p-3"
                >
                  <div>
                    <div class="d-flex align-items-center mb-2">
                      <i class="ri-brain-line me-2 text-primary"></i>
                      <span class="fw-medium">AI Re-analyze</span>
                    </div>
                    <div class="text-muted">
                      Notify when AI auto-repair is triggered for a feed.
                    </div>
                  </div>
                  <div class="form-check form-switch">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="notif-ai-reanalyze"
                      data-notification-type="ai_reanalyze"
                      checked
                      title="Toggle AI re-analyze notifications"
                    />
                  </div>
                </div>
                <div
                  class="list-group-item d-flex justify-content-between align-items-center border-0 p-3"
                >
                  <div>
                    <div class="d-flex align-items-center mb-2">
                      <i class="ri-wifi-off-line me-2 text-primary"></i>
                      <span class="fw-medium">Fail Access</span>
                    </div>
                    <div class="text-muted">Notify when a feed source becomes unreachable.</div>
                  </div>
                  <div class="form-check form-switch">
                    <input
                      class="form-check-input"
                      type="checkbox"
                      id="notif-fail-access"
                      data-notification-type="fail_access"
                      checked
                      title="Toggle fail access notifications"
                    />
                  </div>
                </div>
              </div>
            </div>
            <div class="card-footer bg-transparent d-flex justify-content-end py-3">
              <button type="button" class="btn btn-primary" id="btn-save-notifications">
                <i class="ri-save-3-line me-1"></i> Save Changes
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
