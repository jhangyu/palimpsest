---
// ---
// name: admin-layout
// description: "Main admin layout: sidebar, topbar, footer, command palette, session bootstrap"
// type: layout
// target:
//   layer: frontend
//   domain: layout
// spec_doc: null
// test_file: null
// ---
import { ClientRouter } from 'astro:transitions'
import Head from './partials/_head.astro'
import TopNav from './partials/_topbar.astro'
import Sidebar from './partials/_sidebar.astro'
import Footer from './partials/_footer.astro'
import Scripts from './partials/_scripts.astro'
import CommandPalette from '../../components/app/CommandPalette.astro'

interface Props {
  title: string
  description?: string
  currentPath?: string
  pageScript?: string
  pageCss?: string
  isRtl?: boolean
}

const { title, description, currentPath, pageScript, pageCss, isRtl = false } = Astro.props

const pageSeo = {
  title,
  description: description || `${title} page of the admin dashboard`
}
---

<!doctype html>
<html lang="en" dir={isRtl ? 'rtl' : 'ltr'}>
  <head>
    <Head {...pageSeo} {pageCss} isRtl={isRtl} />
    <ClientRouter />
  </head>
  <body>
    <div class="wrapper">
      <!-- Overlay -->
      <div class="sidebar-overlay"></div>
      <Sidebar currentPath={currentPath || Astro.url.pathname.substring(1)} />
      <!-- Main Content -->
      <main class="main-content px-2">
        <TopNav />
        <!-- Page Content -->
        <div class="content-wrapper py-4">
          <div class="container">
            <slot />
          </div>
        </div>
        <Footer />
      </main>
    </div>
    <!-- All Scripts -->
    <Scripts {pageScript} />
    <CommandPalette />
  </body>
</html>

<!-- Session bootstrap: runs on every admin layout page to verify auth and populate the topbar -->
<script>
  import {
    initSession,
    getCurrentUser,
    renderCurrentUser,
    applyRoleGating
  } from '@/scripts/session'

  document.addEventListener('astro:page-load', () => {
    const user = getCurrentUser()
    if (user) {
      renderCurrentUser(user)
      applyRoleGating(user)
    } else {
      initSession()
    }
  })
</script>
