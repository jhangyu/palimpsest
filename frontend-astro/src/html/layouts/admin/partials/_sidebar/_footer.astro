---
// Footer component for the sidebar
import { getPathPrefix } from '../../../../../utils/path.js'
---

<!-- Sticky Footer -->
<div class="sidebar-footer mt-2">
  <div class="user-profile p-1">
    <div class="d-flex align-items-center" data-bs-toggle="dropdown">
      <div class="avatar position-relative">
        <div
          class="d-flex align-items-center justify-content-center rounded-circle bg-secondary-subtle"
          style="width:36px;height:36px;"
          data-session="user-avatar"
        >
          <i class="ri-user-line text-secondary"></i>
        </div>
        <span class="online-indicator"></span>
      </div>
      <div class="user-info ms-3">
        <span class="fw-semibold" data-session="user-name">Loading...</span>
        <small class="text-muted d-block" style="margin-top: -0.25rem;" data-session="user-email"
        ></small>
      </div>
      <i class="ri-expand-up-down-line ms-auto fs-6"></i>
    </div>
    <ul class="dropdown-menu py-2">
      <li class="border-0 border-bottom border-dashed pb-2">
        <div class="d-flex align-items-center">
          <div class="avatar position-relative">
            <div
              class="d-flex align-items-center justify-content-center rounded-circle bg-secondary-subtle"
              style="width:40px;height:40px;"
              data-session="user-avatar"
            >
              <i class="ri-user-line text-secondary"></i>
            </div>
            <span class="online-indicator"></span>
          </div>
          <div class="ms-3">
            <h6 class="mb-0 fw-semibold" data-session="user-name">Loading...</h6>
            <small class="text-muted" data-session="user-email"></small>
          </div>
        </div>
      </li>
      <li>
        <a
          class="dropdown-item d-flex align-items-center gap-2"
          href={getPathPrefix('/users/profile')}
        >
          <i class="ri-user-line"></i>
          <span>Profile</span>
        </a>
      </li>
      <li>
        <a class="dropdown-item d-flex align-items-center gap-2" href={getPathPrefix('/settings')}>
          <i class="ri-notification-line"></i>
          <span>Notifications</span>
        </a>
      </li>
      <li>
        <a
          class="dropdown-item d-flex align-items-center gap-2 text-danger"
          href="#"
          data-session="logout-btn"
        >
          <i class="ri-logout-box-line"></i>
          <span>Log out</span>
        </a>
      </li>
    </ul>
  </div>
</div>
