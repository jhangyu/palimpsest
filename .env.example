POSTGRES_USER=palimpsest
POSTGRES_PASSWORD=palimpsest
POSTGRES_DB=palimpsest

BACKEND_PORT=8088
ASTRO_PORT=5174
CHROME_PORT=3000
PALIMPSEST_LOG_DIR=/app/log
MAX_CONCURRENT_SESSIONS=10
CHROME_CONNECTION_TIMEOUT=300000

# --- LLM Provider ---
# Enable per-user AI provider profiles with envelope encryption (default: true)
# Set to false for environment-only mode (no KEK required)
LLM_PROVIDER_PROFILES_ENABLED=true
# Path to KEK keyring directory (Docker: /run/secrets/llm_kek, Dev: .dev-secrets)
LLM_KEK_PATH=/run/secrets/llm_kek
# Active KEK version (matches filename: {version}.key)
LLM_KEK_VERSION=v1

# --- LLM Environment Fallback ---
# Used when no user provider is available or profiles are disabled
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_PROTOCOL=openai
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_TEMPERATURE=
LLM_FALLBACK_MAX_TOKENS=4096
LLM_FALLBACK_THINKING=false
LLM_FALLBACK_EFFORT=low

# --- Legacy (deprecated in next major release) ---
# If LLM_FALLBACK_* vars are not set, falls back to MiniMax via this key
# MINIMAX_API_KEY=

# --- Auth & Security ---
# Comma-separated list of allowed origins for CORS (no trailing slash)
# Leave empty for development (allows all). Set in production!
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:8088
# Frontend origin for constructing reset/invite/verify links
FRONTEND_ORIGIN=http://localhost:5174
# Set to true in production (requires HTTPS)
SESSION_COOKIE_SECURE=false
# Session TTL in hours (default 24)
SESSION_TTL_HOURS=24
# Allow public user registration (default false — admin creates users)
AUTH_ALLOW_PUBLIC_REGISTRATION=false
# Development: expose reset/invite/verify links in logs (NEVER true in production)
AUTH_DEV_EXPOSE_RESET_LINK=true
# Optional: file path to write dev reset/invite links (gitignored)
AUTH_DEV_RESET_LINK_FILE=

# --- SMTP (required in production for reset/invite emails) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
